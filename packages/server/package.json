{
  "name": "jiranimo",
  "version": "1.8.0",
  "type": "module",
  "description": "Local automation server for the Jiranimo Jira extension",
  "main": "./dist/index.js",
  "bin": {
    "jiranimo": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Niryo/Jiranimo.git"
  },
  "bugs": {
    "url": "https://github.com/Niryo/Jiranimo/issues"
  },
  "homepage": "https://github.com/Niryo/Jiranimo#readme",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "node ../../scripts/build-server-package.mjs",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:cleanup": "tsx test/e2e/cleanup-jira.ts",
    "test:coverage": "vitest run --coverage",
    "test:all": "tsx test/run-tests.ts"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^17.3.1",
    "playwright": "^1.58.2",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  }
}
