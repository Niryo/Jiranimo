{
  "name": "jiranimo",
  "private": true,
  "workspaces": [
    "packages/assets",
    "server",
    "extension"
  ],
  "scripts": {
    "assets:sync": "npm run sync --workspace=@jiranimo/assets && npm run build --workspace=jiranimo-extension",
    "postinstall": "npm run assets:sync",
    "dev": "bash scripts/dev.sh ./gitPlaygrounds",
    "dev:self": "bash scripts/dev.sh .",
    "dev:server": "bash scripts/dev.sh --server-only ./gitPlaygrounds",
    "dev:clean": "rm -f \"$HOME/.jiranimo/state.json\" && rm -rf \"$HOME/.jiranimo/logs\" && echo 'Jiranimo state cleaned'",
    "dev:reset": "npm run dev:clean && rm -rf .chrome-dev-profile && echo 'Jiranimo reset done'",
    "start": "npm run start --workspace=server",
    "test": "npm run test --workspace=server",
    "test:integration": "npm run test:integration --workspace=server",
    "test:e2e": "npm run test:e2e --workspace=server",
    "test:all": "npm run test:all --workspace=server",
    "test:e2e:cleanup": "npm run test:e2e:cleanup --workspace=server"
  }
}
