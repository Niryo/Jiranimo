{
  "name": "jiranimo",
  "version": "1.9.0",
  "private": true,
  "workspaces": [
    "packages/assets",
    "packages/server",
    "packages/extension"
  ],
  "scripts": {
    "assets:sync": "npm run sync --workspace=@jiranimo/assets && npm run build --workspace=packages/extension",
    "postinstall": "npm run assets:sync",
    "dev": "bash scripts/dev.sh ./gitPlaygrounds",
    "dev:self": "bash scripts/dev.sh .",
    "dev:server": "bash scripts/dev.sh --server-only ./gitPlaygrounds",
    "dev:clean": "rm -f \"$HOME/.jiranimo/state.json\" && rm -rf \"$HOME/.jiranimo/logs\" && echo 'Jiranimo state cleaned'",
    "dev:reset": "npm run dev:clean && rm -rf .chrome-dev-profile && echo 'Jiranimo reset done'",
    "start": "npm run start --workspace=packages/server",
    "build:server": "npm run build --workspace=packages/server",
    "build:extension": "node scripts/build-extension-package.mjs",
    "package:release": "bash scripts/package-release.sh",
    "test:server": "npm run test --workspace=packages/server",
    "test:extension": "npm exec --workspace=packages/server -- vitest run --config ../extension/vitest.config.mjs",
    "test": "npm run test --workspace=packages/server",
    "test:integration": "npm run test:integration --workspace=packages/server",
    "test:e2e": "npm run test:e2e --workspace=packages/server",
    "test:all": "npm run test:all --workspace=packages/server",
    "test:e2e:cleanup": "npm run test:e2e:cleanup --workspace=packages/server",
    "release:next-version": "node scripts/next-version.mjs",
    "release:set-version": "node scripts/set-version.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}
